ENVIRONMENT=production
API_HOST=0.0.0.0
API_PORT=8000

# Set a strong secret and enforce it for non-health API endpoints in production.
REQUIRE_API_KEY=true
API_KEY=replace-with-a-long-random-secret

# Comma-separated browser origins. Keep empty when serving only same-origin UI.
CORS_ORIGINS=https://app.example.com
ALLOWED_HOSTS=app.example.com,api.example.com
MAX_REQUEST_BODY_BYTES=1000000
REDIS_URL=redis://redis:6379/0
WARMUP_WHISPER=false
